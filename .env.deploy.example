# Copy this file to .env.deploy and fill in your own values.
# .env.deploy is gitignored — your personal hosting details never enter the repo.

# Required: the S3 bucket that CloudFront serves from
BUCKET=my-survival-guide-bucket

# Optional: CloudFront distribution ID — if set, deploy-s3.sh invalidates the
# cache so updates go live immediately
CF_DIST=E1234ABCDEFGH

# Optional: your domain (for your own reference / future use)
DOMAIN=example.com
